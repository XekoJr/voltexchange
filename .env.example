PORT=3000
DB_HOST=localhost
DB_PORT=5432
DB_NAME=voltexchange
DB_USER=
DB_PASSWORD=

JWT_SECRET=

# Porta pública do frontend (nginx)
FRONTEND_PORT=8095

# Origem CORS permitida (browser). Sem isto definido, o servidor cai para o
# domínio de produção como fallback — nunca para "aceitar qualquer origem".
CORS_ORIGIN=https://volt.andrepacheco.pt
