services:
  # PostgreSQL Database
  postgres:
    image: postgres:16
    container_name: voltexchange-db
    environment:
      POSTGRES_DB: ${DB_NAME}
      POSTGRES_USER: ${DB_USER}
      POSTGRES_PASSWORD: ${DB_PASSWORD}
    ports:
      - "5432:5432"
    volumes:
      - postgres-data:/var/lib/postgresql/data
      - ./sql/ddl.sql:/docker-entrypoint-initdb.d/01-ddl.sql
      - ./sql/logic.sql:/docker-entrypoint-initdb.d/02-logic.sql
      - ./sql/seed.sql:/docker-entrypoint-initdb.d/03-seed.sql
    networks:
      - voltexchange-network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${DB_USER} -d ${DB_NAME}"]
      interval: 10s
      timeout: 5s
      retries: 5

  # Express.js API
  api:
    build:
      context: ./api
    container_name: voltexchange-api
    environment:
      PORT: ${PORT}
      DB_HOST: postgres
      DB_PORT: ${DB_PORT}
      DB_NAME: ${DB_NAME}
      DB_USER: ${DB_USER}
      DB_PASSWORD: ${DB_PASSWORD}
      JWT_SECRET: ${JWT_SECRET}
    ports:
      - "${PORT}:${PORT}"
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      - voltexchange-network

volumes:
  postgres-data:

networks:
  voltexchange-network:
    driver: bridge