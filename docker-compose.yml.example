services:
  # PostgreSQL Database
  postgres:
    image: postgres:16
    container_name: voltexchange-db
    environment:
      POSTGRES_DB: 
      POSTGRES_USER: 
      POSTGRES_PASSWORD: 
    ports:
      - "5432:5432"
    volumes:
      - postgres-data:/var/lib/postgresql/data
      - ./migrations/01-ddl-voltexchange.sql:/docker-entrypoint-initdb.d/01-schema.sql
      - ./migrations/02-partitions.sql:/docker-entrypoint-initdb.d/02-partitions.sql
    networks:
      - voltexchange-network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U root"]
      interval: 10s
      timeout: 5s
      retries: 5

  # Spring Boot API
  api:
    build:
      context: ./api
      dockerfile: ../Dockerfile.gradle
    container_name: voltexchange-api
    depends_on:
      postgres:
        condition: service_healthy
    environment:
      SPRING_DATASOURCE_URL: jdbc:postgresql://postgres:5432/voltexchange
      SPRING_DATASOURCE_USERNAME: root
      SPRING_DATASOURCE_PASSWORD: root
      SPRING_PROFILES_ACTIVE: prod
      JWT_SECRET: VoltExchange2026SecretKeyMuitoSegura123456789
    ports:
      - "8080:8080"
    networks:
      - voltexchange-network
    restart: unless-stopped

volumes:
  postgres-data:

networks:
  voltexchange-network:
    driver: bridge